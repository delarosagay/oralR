Package: oralR
Type: Package
Title: Tools for Dental Data Analysis in R
Version: 0.1.0
Authors@R: c(
    person("Cristina", "de-la-Rosa-Gay", email = "mdelarosa@uoc.edu", role = c("aut", "cre"), comment = c(ORCID = "0009-0004-1518-8648")),
